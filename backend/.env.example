# ======================================
# VoiceHR Environment Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# PostgreSQL
DB_NAME=voicehr_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# OpenAI (for Whisper API - OPTIONAL)
# Get your key from: https://platform.openai.com/api-keys
# Note: The app works WITHOUT this key (uses free browser speech recognition)
OPENAI_API_KEY=sk-your-openai-api-key-here
